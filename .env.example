# Copy to .env.local and fill in real values.
# DATABASE_URL is the only required variable. All others have safe defaults.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ake:ake@localhost:5432/ake
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── LLM Router ────────────────────────────────────────────────────────────────
# Provider: anthropic | openai | azure | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=                  # override endpoint (e.g. http://localhost:11434/v1)
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120

# Fallback chain: comma-separated "provider/model" strings tried in order on failure
# LLM_FALLBACK_CHAIN=anthropic/claude-haiku-4-5-20251001,openai/gpt-4o-mini

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# TRACE_STORE_URL=               # if set, structured traces are written here
